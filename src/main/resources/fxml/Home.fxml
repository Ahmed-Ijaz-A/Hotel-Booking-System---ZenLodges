<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.xcoders.controller.HomePageController"
            stylesheets="@../styles/style.css"
            prefWidth="1100" prefHeight="700"
            styleClass="root-pane">

    <top>
        <HBox styleClass="navbar" alignment="CENTER" style="-fx-padding: 15 40; -fx-background-color: #ffffff;">
            
            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="20" alignment="CENTER">
                <HBox alignment="CENTER_LEFT" spacing="0">
                    <Label text="Zen" styleClass="title-zen" style="-fx-font-size: 24;"/>
                    <Label text="Lodges" styleClass="title-lodges" style="-fx-font-size: 24;"/>
                </HBox>
                <ComboBox fx:id="searchComboBox" editable="true" promptText="Search by hotel name or location..." 
                          styleClass="input-field" style="-fx-min-width: 320;"/>
                <Button fx:id="searchBtn" text="Search" onAction="#onSearchClick" styleClass="btn-primary"/>
            </HBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="browseRoomsBtn" text="Browse Rooms" onAction="#onBrowseRoomsClick" 
                        styleClass="btn-primary" visible="false" managed="false"/>
                <Button fx:id="myBookingsBtn" text="My Bookings" onAction="#onMyBookingsClick" 
                        styleClass="btn-primary" visible="false" managed="false"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="false" style="-fx-background-color: transparent; -fx-control-inner-background: #f0f2f5;">
            <VBox spacing="0">
            
                <StackPane alignment="CENTER" style="-fx-background-color: #1a1a2e; -fx-padding: 40 40;">
                    <ImageView fitWidth="1020" fitHeight="400" preserveRatio="false">
                        <image>
                            <Image url="@../images/img.jpg" backgroundLoading="true"/>
                        </image>
                        <clip>
                            <Rectangle width="1020" height="400" arcWidth="30" arcHeight="30"/>
                        </clip>
                    </ImageView>

                    <VBox alignment="CENTER" style="-fx-background-color: #1a1a2e; -fx-padding: 40 0;">
                    
                    <StackPane alignment="CENTER" maxWidth="1020">
                        
                        <ImageView fitWidth="1020" fitHeight="400" preserveRatio="false">
                            <image>
                                <Image url="@../images/img.jpg" backgroundLoading="true"/>
                            </image>
                            <clip>
                                <Rectangle width="1020" height="400" arcWidth="30" arcHeight="30"/>
                            </clip>
                        </ImageView>

                        <VBox spacing="30" alignment="CENTER" maxWidth="700" maxHeight="250" 
                              styleClass="login-card" 
                              style="-fx-background-color: rgba(255, 255, 255, 0.85); -fx-padding: 40; -fx-background-radius: 20;">
                            
                            <HBox alignment="CENTER" spacing="0">
                                <Label text="Zen" styleClass="title-zen" style="-fx-font-size: 48;"/>
                                <Label text="Lodges" styleClass="title-lodges" style="-fx-font-size: 48;"/>
                            </HBox>
                            
                            <Label text="Your perfect hotel booking experience starts here" styleClass="hero-subheading" style="-fx-font-size: 16;"/>
                            
                            <HBox spacing="15" alignment="CENTER">
                                <Button fx:id="loginBtn" text="Login" onAction="#onLoginClick" styleClass="btn-primary"/>
                                <Button fx:id="heroBrowseRoomsBtn" text="Browse Rooms" onAction="#onBrowseRoomsClick" styleClass="btn-primary"/>
                                <Button text="Register Your Hotel" onAction="#onRegisterHotelClick" styleClass="btn-primary"/>
                            </HBox>
                            
                        </VBox>
                    </StackPane>
                </VBox>
                </StackPane>

                <Region fx:id="spacer" style="-fx-min-height: 5; -fx-background-color: #003cfd;"/>

                <VBox spacing="20" style="-fx-padding: 60 40; -fx-background-color: #1a1a2e;" alignment="CENTER">
                    <VBox spacing="20" maxWidth="1100" alignment="CENTER_LEFT">
                        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 20 0 0 0;">
                            <Label text="Featured" style="-fx-text-fill: #003cfd; -fx-font-size: 28; -fx-font-weight: bold;"/>
                            <Label text="Hotels" style="-fx-text-fill: #ffffff; -fx-font-size: 28; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label text="Browse our approved partner hotels" styleClass="hero-subheading"/>
                        
                        <GridPane fx:id="hotelGridPane" hgap="25" vgap="30" style="-fx-padding: 20 0;">
                            <columnConstraints>
                                <javafx.scene.layout.ColumnConstraints percentWidth="25.0"/>
                                <javafx.scene.layout.ColumnConstraints percentWidth="25.0"/>
                                <javafx.scene.layout.ColumnConstraints percentWidth="25.0"/>
                                <javafx.scene.layout.ColumnConstraints percentWidth="25.0"/>
                            </columnConstraints>
                            
                            <StackPane style="-fx-cursor: hand;" 
                                       minWidth="240" prefWidth="240" maxWidth="240" 
                                       minHeight="160" prefHeight="160" maxHeight="160" 
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                                       GridPane.halignment="CENTER">
                                <effect>
                                    <DropShadow color="rgba(0,0,0,0.15)" radius="15" spread="0.05" offsetY="8"/>
                                </effect>
                                
                                <ImageView fitWidth="240" fitHeight="160" preserveRatio="false">
                                    <image>
                                        <Image url="@../images/img.jpg" backgroundLoading="true"/>
                                    </image>
                                    <clip>
                                        <Rectangle width="240" height="160" arcWidth="30" arcHeight="30"/>
                                    </clip>
                                </ImageView>
                                
                                <Region minWidth="240" prefWidth="240" maxWidth="240" 
                                        minHeight="160" prefHeight="160" maxHeight="160" 
                                        style="-fx-background-color: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 70%); -fx-background-radius: 15;"/>
                                
                                <VBox alignment="BOTTOM_LEFT" spacing="2" 
                                      minWidth="240" prefWidth="240" maxWidth="240" 
                                      style="-fx-padding: 15;">
                                    <Label text="Corporate Stays" wrapText="true" 
                                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                                    <Label text="San Francisco, California" 
                                           style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.9);"/>
                                    <Label text="Type: Business" 
                                           style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);"/>
                                </VBox>
                            </StackPane>
                            
                            </GridPane>
                        
                        <Label fx:id="noHotelsLabel" text="No hotels available yet. Check back soon!" 
                               styleClass="hero-subheading" style="-fx-alignment: center; -fx-pref-width: 1000;" managed="false" visible="false"/>
                    </VBox>
                </VBox>
            
                <Region fx:id="spacer" style="-fx-min-height: 5; -fx-background-color: #003cfd;"/>

                <VBox spacing="15" styleClass="footer" style="-fx-padding: 20 40; -fx-background-color: #1a1a2e;">
                    <HBox spacing="80" alignment="TOP_LEFT">
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="0">
                                <Label text="Zen" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 18;"/>
                                <Label text="Lodges" style="-fx-text-fill: #c8c8e0; -fx-font-weight: bold; -fx-font-size: 18;"/>
                            </HBox>
                            <Label text="Your perfect hotel booking experience" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.8);"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Contact Us" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                            <Label text="Email: info@zenlodges.com" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.8);"/>
                            <Label text="Phone: +1-800-ZENODGES" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.8);"/>
                            <Label text="Address: 123 Hotel Street, CA 94105" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.8);"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Support Hours" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                            <Label text="Monday - Friday: 9:00 AM - 6:00 PM" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.8);"/>
                            <Label text="Weekend: 10:00 AM - 4:00 PM" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.8);"/>
                        </VBox>
                    </HBox>
                    <Label text="© 2026 ZenLodges. All rights reserved." style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.6); -fx-padding: 15 0 0 0;" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>