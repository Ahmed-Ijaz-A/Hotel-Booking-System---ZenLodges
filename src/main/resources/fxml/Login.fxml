<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.xcoders.controller.LoginController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="600">

    <!-- Background image (place your image at resources/images/login-bg.jpg) -->
    <ImageView fx:id="bgImageView" preserveRatio="false"
               fitWidth="900" fitHeight="600"
               styleClass="bg-image">
        <image>
            <Image url="@../images/image 5.png" backgroundLoading="true"/>
        </image>
    </ImageView>

    <!-- Centred card -->
    <VBox alignment="CENTER" spacing="15"
          styleClass="login-card"
          maxWidth="500" maxHeight="420">

        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Title -->
        <HBox alignment="CENTER" spacing="0">
            <Label text="Zen" styleClass="title-zen">
                <font><Font size="28"/></font>
            </Label>
            <Label text="Lodges" styleClass="title-lodges">
                <font><Font size="28"/></font>
            </Label>
        </HBox>

        <!-- Subtitle -->
        <Label text="Stress free booking experience!" styleClass="subtitle-label"/>

        <!-- Email -->
        <TextField fx:id="emailField" promptText="Email address"
                   styleClass="input-field" maxWidth="300"/>

        <!-- Password -->
        <PasswordField fx:id="passwordField" promptText="Password"
                       styleClass="input-field" maxWidth="300"/>

        <!-- Role Selector -->
        <Label text="Login as:" style="-fx-font-size: 12; -fx-text-fill: #666666;"/>
        <ComboBox fx:id="roleCombo" promptText="Select Role" maxWidth="300"
                  style="-fx-font-size: 13;"/>

        <!-- Error message (hidden by default) -->
        <Label fx:id="errorLabel" text="" styleClass="error-label"
               wrapText="true" maxWidth="300"/>

        <!-- Login button -->
        <Button text="Login" onAction="#handleLogin"
                styleClass="primary-btn" maxWidth="300" prefHeight="38"/>

        <!-- Register link -->
        <Hyperlink text="Create Account" onAction="#handleCreateAccount"
                   styleClass="link"/>

    </VBox>

</StackPane>
