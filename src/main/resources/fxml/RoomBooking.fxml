<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.xcoders.controller.RoomBookingController"
      spacing="25" alignment="TOP_CENTER"
      style="-fx-background-color: rgba(26, 26, 46, 0.95); -fx-background-radius: 15; -fx-padding: 35;"
      maxWidth="500">

    <effect>
        <DropShadow color="rgba(0,0,0,0.4)" radius="20" spread="0.1" offsetY="8"/>
    </effect>

    <VBox alignment="CENTER" spacing="5">
        <Label text="Book Your Room" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
        <Label text="Select your dates to confirm availability." style="-fx-font-size: 14; -fx-text-fill: #c8c8e0;" />
    </VBox>

    <VBox spacing="10" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 10; -fx-padding: 20;">
        <Label text="Room Details" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #003cfd;" />
        
        <Label fx:id="roomDetailsLabel" text="No room selected" style="-fx-text-fill: #ffffff; -fx-font-size: 14;" wrapText="true"/>
        
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;">
            <Label text="Price per Night:" style="-fx-font-weight: bold; -fx-text-fill: #c8c8e0;" />
            <Label fx:id="priceLabel" text="0.00" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold; -fx-font-size: 16;" />
        </HBox>
    </VBox>

    <VBox spacing="15" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 10; -fx-padding: 20;">
        <Label text="Select Your Dates" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #003cfd;" />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Check-in:" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" minWidth="80" />
            <DatePicker fx:id="checkInDatePicker" promptText="Select date" styleClass="input-field" prefHeight="38" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Check-out:" style="-fx-font-weight: bold; -fx-text-fill: #ffffff;" minWidth="80" />
            <DatePicker fx:id="checkOutDatePicker" promptText="Select date" styleClass="input-field" prefHeight="38" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
    </VBox>

    <Label fx:id="availabilityLabel" text="" style="-fx-font-size: 14; -fx-text-fill: #ff6b6b; -fx-font-weight: bold;" wrapText="true" alignment="CENTER"/>

    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="cancelButton" text="Cancel" onAction="#onCancel"
                style="-fx-background-color: transparent; -fx-text-fill: #c8c8e0; -fx-font-weight: bold; -fx-padding: 10 25; -fx-cursor: hand; -fx-font-size: 14;" />
                
        <Button fx:id="bookButton" text="Book Now" onAction="#onBookRoom"
                style="-fx-background-color: #003cfd; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 35; -fx-cursor: hand; -fx-font-size: 14;" />
    </HBox>

</VBox>