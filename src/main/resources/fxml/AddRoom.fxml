<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.xcoders.controller.AddRoomController"
      alignment="TOP_CENTER" spacing="20"
      styleClass="content-area">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Heading -->
    <Label text="Add New Room" styleClass="title-label">
        <font><Font size="22"/></font>
    </Label>

    <!-- Form card -->
    <VBox alignment="CENTER" spacing="15"
          styleClass="card" maxWidth="480">

        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <GridPane hgap="12" vgap="14" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="130"/>
                <ColumnConstraints minWidth="220" prefWidth="260"/>
            </columnConstraints>

            <!-- Room Number -->
            <Label text="Room Number" styleClass="form-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="roomNumberField" promptText="e.g. 101"
                       styleClass="input-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <!-- Type -->
            <Label text="Type" styleClass="form-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="typeCombo" promptText="Select type"
                      styleClass="input-field" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="1" GridPane.rowIndex="1">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Single"/>
                        <String fx:value="Double"/>
                        <String fx:value="Deluxe"/>
                        <String fx:value="Suite"/>
                    </FXCollections>
                </items>
            </ComboBox>

            <!-- Price -->
            <Label text="Price" styleClass="form-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="priceField" promptText="e.g. 5000.00"
                       styleClass="input-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <!-- Status -->
            <Label text="Status" styleClass="form-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <ComboBox fx:id="statusCombo" promptText="Select status"
                      styleClass="input-field" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="1" GridPane.rowIndex="3">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="AVAILABLE"/>
                        <String fx:value="MAINTENANCE"/>
                    </FXCollections>
                </items>
            </ComboBox>
        </GridPane>

        <!-- Message label -->
        <Label fx:id="messageLabel" text="" styleClass="error-label"
               wrapText="true" maxWidth="390"/>

        <!-- Add button -->
        <Button text="Add Room" onAction="#handleAddRoom"
                styleClass="primary-btn" maxWidth="390" prefHeight="38"/>

    </VBox>

</VBox>
