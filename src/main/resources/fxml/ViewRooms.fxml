<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.xcoders.controller.ViewRoomsController"
      alignment="TOP_CENTER" spacing="25"
      style="-fx-background-color: rgba(26, 26, 46, 0.85); -fx-background-radius: 20; -fx-padding: 40;">

    <effect>
        <DropShadow color="rgba(0,0,0,0.3)" radius="15" spread="0.1" offsetY="5"/>
    </effect>

    <VBox alignment="CENTER" spacing="5">
        <Label text="All Rooms" style="-fx-text-fill: #ffffff; -fx-font-size: 32; -fx-font-weight: bold;"/>
        <Label text="View and manage the inventory of your hotel rooms" style="-fx-text-fill: #c8c8e0; -fx-font-size: 14;"/>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" 
          style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 15; -fx-padding: 20;">

        <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS"
                   styleClass="dark-table" style="-fx-background-color: transparent;">

            <columns>
                <TableColumn fx:id="hotelColumn" text="Hotel ID" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="hotelId"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Room ID" prefWidth="80">
                    <cellValueFactory>
                        <PropertyValueFactory property="roomId"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Room Number" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="roomNumber"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Type" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="type"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Price" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="price"/>
                    </cellValueFactory>
                </TableColumn>

                <TableColumn text="Status" prefWidth="140">
                    <cellValueFactory>
                        <PropertyValueFactory property="status"/>
                    </cellValueFactory>
                </TableColumn>
                
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="100"/>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

        </TableView>

    </VBox>

</VBox>